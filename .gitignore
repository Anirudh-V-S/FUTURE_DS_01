# Git Ignore file for Sales Performance Analytics Project
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebooks checkpoints
.ipynb_checkpoints

# Environments
.env
.venv
env/
venv/
ENV/

# Large Datasets (Never commit raw massive files)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/cleaned_superstore.csv

# Operating System Files
.DS_Store
Thumbs.db
